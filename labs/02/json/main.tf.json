{
  "terraform": {
    "required_providers": {
      "docker": {
        "source": "kreuzwerker/docker",
        "version": "3.6.2"
      }
    }
  },
  "provider": {
    "docker": {
      "host": "unix:///var/run/docker.sock"
    }
  },
  "resource": {
    "docker_image": {
      "apache_web": {
        "name": "httpd:latest"
      }
    },
    "docker_container": {
      "web_server": {
        "image": "${docker_image.apache_web.image_id}",
        "name": "web_server",
        "ports": [
          {
            "internal": 80,
            "external": 88
          }
        ]
      },
      "webserver_2": {
        "name": "webserver_2",
        "image": "${docker_image.apache_web.image_id}",
        "ports": [
          {
            "internal": 80,
            "external": 89
          }
        ]
      }
    }
  }
}
