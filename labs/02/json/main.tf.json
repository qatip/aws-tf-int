{
  "terraform": {
    "required_providers": {
      "docker": {
        "source": "kreuzwerker/docker",
        "version": "3.6.2"
      }
    }
  },
  "provider": {
    "docker": {
      "host": "unix:///var/run/docker.sock"
    }
  },
  "resource": {
    "docker_image": {
      "apache_web": {
        "name": "httpd:latest"
      }
    },
    "docker_container": {
      "webserver": {
        "image": "${docker_image.apache_web.image_id}",
        "name": "webserver",
        "ports": [
          {
            "internal": 80,
            "external": 88
          }
        ]
      }
    }
  }
}
